{
  "name": "tiger-openapi",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo workspace for the Tiger OpenAPI SDK.",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "dev": "turbo run dev --parallel",
    "jsr:check": "node ./scripts/sync-jsr-manifests.mjs --check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "pnpm release:npm && pnpm release:jsr",
    "release:jsr": "node ./scripts/publish-jsr.mjs",
    "release:npm": "changeset publish",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version && node ./scripts/sync-jsr-manifests.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^17.4.0",
    "prettier": "^3.3.3",
    "tsup": "^8.5.1",
    "turbo": "^2.5.8",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.6"
  },
  "packageManager": "pnpm@9.15.0"
}
