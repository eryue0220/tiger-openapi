{
  "name": "tiger-openapi-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared utilities for the Tiger OpenAPI SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b .",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -b ."
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
