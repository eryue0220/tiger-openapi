{
  "name": "@tiger-openapi/stream",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime stream layer for the Tiger OpenAPI SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b .",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -b ."
  },
  "dependencies": {
    "@tiger-openapi/pb": "workspace:*",
    "@tiger-openapi/shared": "workspace:*"
  }
}
