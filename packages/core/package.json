{
  "name": "tiger-openapi-core",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-environment Tiger OpenAPI SDK entrypoint.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b .",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -b ."
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "tiger-openapi-http": "workspace:*",
    "tiger-openapi-pb": "workspace:*",
    "tiger-openapi-stream": "workspace:*",
    "tiger-openapi-shared": "workspace:*"
  }
}
